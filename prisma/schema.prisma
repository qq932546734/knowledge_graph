generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RelationType {
  PARENT_CHILD
  RELATED
}

enum PracticeMode {
  NODE_RECALL
  QUESTION_ANSWER
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  passwordHash  String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  knowledgeNodes KnowledgeNode[]
  nodeRelations NodeRelation[]
  questions     InterviewQuestion[]
  reviewEvents  ReviewEvent[]
  practiceEvents PracticeEvent[]
  backupValidationTokens BackupValidationToken[]
}

model KnowledgeNode {
  id              String            @id @default(cuid())
  userId          String
  title           String
  contentMd       String
  tags            String[]
  difficulty      Int
  sourceUrl       String?
  lastReviewedAt  DateTime?
  nextReviewAt    DateTime?
  sm2EF           Float             @default(2.5)
  sm2Repetition   Int               @default(0)
  sm2IntervalDays Int               @default(0)
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromRelations   NodeRelation[]    @relation("FromNode")
  toRelations     NodeRelation[]    @relation("ToNode")
  questions       InterviewQuestion[]
  reviewEvents    ReviewEvent[]
  practiceEvents  PracticeEvent[]

  @@index([userId, deletedAt])
  @@index([userId, nextReviewAt, deletedAt])
  @@index([userId, updatedAt, deletedAt])
}

model NodeRelation {
  id           String         @id @default(cuid())
  userId       String
  fromNodeId   String
  toNodeId     String
  relationType RelationType
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromNode     KnowledgeNode  @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode       KnowledgeNode  @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([userId, relationType, deletedAt])
  @@index([userId, fromNodeId, toNodeId, relationType])
  @@index([userId, deletedAt])
}

model InterviewQuestion {
  id                String         @id @default(cuid())
  userId            String
  nodeId            String
  question          String
  referenceAnswerMd String
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  node              KnowledgeNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  practiceEvents    PracticeEvent[]

  @@index([userId, nodeId, deletedAt])
  @@index([userId, updatedAt, deletedAt])
}

model ReviewEvent {
  id             String         @id @default(cuid())
  userId         String
  nodeId         String
  reviewedAt     DateTime       @default(now())
  quality        Int
  efBefore       Float
  efAfter        Float
  intervalBefore Int
  intervalAfter  Int
  nextReviewAt   DateTime
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  node           KnowledgeNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([userId, reviewedAt])
  @@index([userId, nodeId, reviewedAt])
}

model PracticeEvent {
  id         String            @id @default(cuid())
  userId     String
  mode       PracticeMode
  nodeId     String
  questionId String?
  answeredAt DateTime          @default(now())
  selfScore  Int
  note       String?
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  node       KnowledgeNode     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  question   InterviewQuestion? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@index([userId, mode, answeredAt])
  @@index([userId, questionId, answeredAt])
  @@index([userId, nodeId, answeredAt])
}

model BackupValidationToken {
  token       String   @id
  userId      String
  payloadHash String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}
