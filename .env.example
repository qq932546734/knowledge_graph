# PostgreSQL connection string (local default)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowledge_graph?schema=public"

# NextAuth secret (at least 32 chars). Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"
AUTH_TRUST_HOST="true"

# Optional: login rate limit
RATE_LIMIT_WINDOW_MINUTES="15"
RATE_LIMIT_MAX_ATTEMPTS="5"

# Optional: CSRF headers/cookies
CSRF_COOKIE_NAME="kg_csrf_token"
CSRF_HEADER_NAME="x-csrf-token"

# Optional: seed credentials
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeThisPassword123!"
